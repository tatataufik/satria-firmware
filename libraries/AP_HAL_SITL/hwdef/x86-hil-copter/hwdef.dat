# x86-hil-copter: SITL board for HIL with X-Plane on x86/laptop — helicopter/copter airframe.
# Inherits the base SITL HAL; builds natively on x86, no cross-compile needed.
# Uses xplane_heli.json DREF map: collective on CH3, cyclic roll CH1, cyclic pitch CH2, yaw CH4.
#
# Build:  ./waf configure --board sitl && ./waf copter
# Run:    sim_vehicle.py -v ArduCopter -f heli-x86-hil --model xplane
#
# Parameters for the HIL/XPlane session are in defaults.parm.
include ../sitl/hwdef.dat

# Use the helicopter DREF map for X-Plane.
define XPLANE_JSON "xplane_heli.json"
