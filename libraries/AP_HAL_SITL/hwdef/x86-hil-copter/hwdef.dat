# x86-hil-copter: SITL board for HIL with X-Plane on x86/laptop, ArduCopter.
# Vehicle: ArduCopter X-frame quadcopter (FRAME_CLASS=1, FRAME_TYPE=1).
# Requires a custom X-Plane aircraft with 4 electric motors (see xplane_quad.json).
#
# Build:  ./waf configure --board x86-hil-copter && ./waf copter
# Run:    sim_vehicle.py -v ArduCopter --model xplane --map --console
include ../sitl/hwdef.dat

define XPLANE_JSON "xplane_quad.json"
