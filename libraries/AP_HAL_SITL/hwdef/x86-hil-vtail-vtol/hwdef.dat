# x86-hil-vtail-vtol: SITL board for HIL with X-Plane on x86/laptop — V-tail QuadPlane VTOL.
# Vehicle: ArduPlane QuadPlane with V-tail fixed-wing + H-frame quad lift motors.
#
# Channel layout:
#   CH1 = Aileron
#   CH2 = Vtail_right  (elevator - rudder) * MIXING_GAIN
#   CH3 = Throttle     forward pusher motor  → engine[4]
#   CH4 = Vtail_left   (elevator + rudder)  * MIXING_GAIN
#   CH5 = Motor1  front-right  CW  → engine[0]
#   CH6 = Motor2  rear-left    CW  → engine[1]
#   CH7 = Motor3  front-left  CCW  → engine[2]
#   CH8 = Motor4  rear-right  CCW  → engine[3]
#
# X-Plane model must have 5 engines:
#   engine[0-3] = quad lift motors  (H-frame arms)
#   engine[4]   = forward pusher motor
#
# Build:  ./waf configure --board x86-hil-vtail-vtol && ./waf plane
# Run:    sim_vehicle.py -v ArduPlane --model xplane --map --console
include ../sitl/hwdef.dat

define XPLANE_JSON "xplane_vtail_vtol.json"
