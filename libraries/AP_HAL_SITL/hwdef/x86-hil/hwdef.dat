# x86-hil: SITL board for HIL (Hardware-in-the-Loop) with X-Plane on x86/laptop.
# Vehicle: ArduPlane standard 4-channel fixed-wing (aileron, elevator, throttle, rudder).
# Inherits the base SITL HAL; no cross-compile toolchain — builds natively.
#
# Channel layout:
#   CH1 = Aileron   SERVO1_FUNCTION=4
#   CH2 = Elevator  SERVO2_FUNCTION=19
#   CH3 = Throttle  SERVO3_FUNCTION=70
#   CH4 = Rudder    SERVO4_FUNCTION=21
#
# Build:  ./waf configure --board x86-hil && ./waf plane
# Run:    sim_vehicle.py -v ArduPlane --model xplane --map --console
include ../sitl/hwdef.dat

define XPLANE_JSON "xplane_plane.json"
